# Optional host port for the web interface.
LIGQ_WEB_PORT=8080

# Optional Hugging Face token for authenticated/rate-limited downloads.
HF_TOKEN=

# Public release images. Override these to test local or alternate builds.
LIGQ_API_IMAGE=ghcr.io/gschottlender/ligq-2-api:gui
LIGQ_WEB_IMAGE=ghcr.io/gschottlender/ligq-2-web:gui
